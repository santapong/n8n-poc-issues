# Copy to .env and adjust. See docker-compose.yml for how each is used.

# ── Postgres ──
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_pass
POSTGRES_DB=n8n

# ── n8n core ── (same encryption key on main + worker!)
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-32char-secret-0001
GENERIC_TIMEZONE=Asia/Bangkok
TZ=Asia/Bangkok
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:8080/

# ── OOM knobs ──
NODE_MAX_OLD_SPACE_SIZE=512
N8N_MEM_LIMIT=1024m
N8N_PAYLOAD_SIZE_MAX=256
